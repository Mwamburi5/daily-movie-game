{
  "name": "matchcut",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "verify": "node sim/verify.ts",
    "verify:chronology": "node sim/chronology-verify.ts",
    "verify:solo": "node sim/solo-verify.ts",
    "verify:connections": "node sim/connections-verify.ts",
    "eval:chronology": "node sim/chronology-eval.ts",
    "gen:connections": "node --max-old-space-size=12288 sim/connections-gen.ts",
    "build:chronology-pool": "node scripts/build-chronology-pool.ts",
    "tmdb:probe": "node scripts/tmdb-probe.ts",
    "tmdb:audit": "node scripts/tmdb-audit.ts",
    "tmdb:dates": "node scripts/tmdb-date-audit.ts",
    "tmdb:draft": "node scripts/tmdb-date-draft.ts",
    "audit:names": "node scripts/name-audit.ts",
    "sim": "node sim/duel-sim.ts",
    "eval": "node sim/eval.ts"
  },
  "dependencies": {
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
